# configs
include ~/.config/sway/monitors.conf
include ~/.config/sway/environment.conf
include ~/.config/sway/variables.conf
include ~/.config/sway/general.conf
include ~/.config/sway/keybindings.conf
include ~/.config/sway/windowrules.conf

# swayidle + swaylock
exec swayidle -w \
  timeout 1800 'swaylock -f && swaymsg reload' \
  timeout 1830 'swaymsg "output * dpms off"' \
  resume 'swaymsg "output * dpms on"' \
  before-sleep 'swaylock -f && swaymsg reload'
